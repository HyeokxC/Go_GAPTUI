# Kimchi Premium Monitor - Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# API Keys (for deposit/withdrawal status & transfer)
# ============================================

# Binance API Keys
# Get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Upbit API Keys
# Get from: https://upbit.com/mypage/open_api_management
UPBIT_API_KEY=
UPBIT_SECRET_KEY=

# Bithumb API Keys
# Get from: https://www.bithumb.com/mypage/api
BITHUMB_API_KEY=
BITHUMB_SECRET_KEY=

# Bybit API Keys
# Get from: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# Bitget API Keys (passphrase required)
# Get from: https://www.bitget.com/account/newapi
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# OKX API Keys (passphrase required)
# Get from: https://www.okx.com/account/my-api
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Gate.io API Keys
# Get from: https://www.gate.io/myaccount/apikeys
GATE_API_KEY=
GATE_SECRET_KEY=

# ============================================
# Proxy Configuration (Optional)
# ============================================
# Leave empty for direct connection
# Supports: http, https, socks5

# Single proxy for all exchanges
# PROXY_URL=http://127.0.0.1:7890
# PROXY_URL=socks5://127.0.0.1:1080

# Per-exchange proxy (overrides PROXY_URL if set)
# BINANCE_PROXY=http://127.0.0.1:7890
# UPBIT_PROXY=http://127.0.0.1:7891
# BITHUMB_PROXY=http://127.0.0.1:7892

# Proxy authentication (if required)
# PROXY_USERNAME=
# PROXY_PASSWORD=
